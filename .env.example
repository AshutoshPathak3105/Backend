# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env for local development.
# In production (Render), add each key in:
#   Dashboard → Your Service → Environment → Add Environment Variable
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/jobportal?retryWrites=true&w=majority

# A long random secret used to sign JWT tokens  (min 32 chars recommended)
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Optional (have working defaults) ─────────────────────────────────────────

# JWT token expiry  (e.g. 7d, 30d, 1h)
JWT_EXPIRE=30d

# Set to "production" on Render; "development" locally
NODE_ENV=production

# Port — Render assigns this automatically; leave blank on Render
PORT=5000

# Your deployed frontend URL (used for CORS + email links)
# If hosting on Firebase: https://your-app.web.app
# If hosting on Netlify:  https://your-app.netlify.app
# Comma-separate multiple origins if needed: https://app1.com,https://app2.com
CLIENT_URL=https://your-frontend-url.web.app

# ── AI Features (Google Gemini) ───────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email / OTP (Nodemailer via Gmail) ───────────────────────────────────────
# Use a Gmail App Password (NOT your normal password):
#   Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
